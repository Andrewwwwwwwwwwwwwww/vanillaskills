  "vanillaskills.lane.health.header": "Raises your maximum health.\n+2 hearts per tier, up to +20 hearts.",
  "vanillaskills.lane.speed.header": "Move faster on foot.\n+2% walk speed per tier, up to +30%.",
  "vanillaskills.lane.mining.header": "Mine blocks faster.\nStacking mining efficiency — max it out to\ninstamine stone with an Efficiency V pickaxe.",
  "vanillaskills.lane.luck.header": "Raises your Luck (+0.5 per tier, up to +5).\nBetter loot from chests, vaults & fishing.",
  "vanillaskills.lane.damage.header": "Hit harder in melee.\n+0.5 flat & +3% weapon damage per tier\n(up to +5 & +30%). Scales with your weapon.",
  "vanillaskills.lane.guardian.header": "Take less damage.\n+1 armor per tier, up to +10.",
  "vanillaskills.lane.reach.header": "Place and hit from further away.\n+0.5 block & entity reach per tier (max +2.5).",
  "vanillaskills.lane.mountaineer.header": "Auto-step up ledges up to 1.1 blocks tall.\nSneak to walk normally. Toggle: /skill toggle stepup.",
  "vanillaskills.lane.aquatic.header": "Underwater mastery: longer breath,\nfaster swimming, and quicker underwater mining.",
  "vanillaskills.lane.armorsmith.header": "Unlocks crafting each armor tier,\nHardwood up to Dragon. Paid in Quest Shards.",
  "vanillaskills.lane.toolsmith.header": "Unlocks crafting each tool tier,\nHardwood up to Dragon. Paid in Quest Shards.",
  "vanillaskills.lane.brewmaster.header": "Beneficial potions last longer —\n+10% duration per tier, up to +50%.",
  "vanillaskills.lane.evasion.header": "Chance to fully dodge incoming arrows.\n+2% per tier, up to 20%.",
  "vanillaskills.lane.cultivator.header": "Bonus crops when harvesting mature crops.\n+20% chance per tier, up to a guaranteed extra.",
  "vanillaskills.lane.nightvision.header": "A capstone granting permanent Night Vision.\nToggle with /skill toggle nightvision.",
  "vanillaskills.recipe.hardwood": "Hardwood",
  "vanillaskills.recipe.hardwood.desc": "The base material for all Hardwood gear.\nThen craft any tool or armor in its normal\nshape using these Wood blocks (not planks).\nHardwood swords & axes poison on hit.",
  "vanillaskills.recipe.rose_gold_ingot_4": "Rose Gold Ingot (×4)",
  "vanillaskills.recipe.steel_ingot_anvil_iron_iron": "Steel Ingot (Anvil: iron + iron)",
